{
  "name": "webcaster",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "compile": "bun build src/server/index.ts drizzle/**/*.sql --compile --outfile out/WebCaster.exe --target=bun-windows-x64 --windows-icon=src/server/icon.ico --title=WebCaster --asset-naming=[name].[ext] --bytecode --format=esm"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@tanstack/query-db-collection": "^1.0.23",
    "@tanstack/react-db": "^0.1.70",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "drizzle-orm": "^0.45.1",
    "fast-xml-parser": "^5.4.1",
    "gender-detection-from-name": "^1.11.4",
    "inworld-tts": "^2.2.0",
    "not-the-systray": "^0.3.1",
    "open": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stylemap": "^0.4.3",
    "valibot": "^1.2.0"
  }
}